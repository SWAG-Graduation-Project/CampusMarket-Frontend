<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/detailbackgruound"
    tools:context=".SellActivity">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/backbutton"
            android:layout_width="50dp"
            android:layout_height="45dp"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/tvStoreTitle"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:layout_marginStart="10dp"
            android:background="#E6C7A0"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="상품 등록하기"
            android:textColor="#3A2A1C"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 사진 업로드 영역 -->
    <HorizontalScrollView
        android:id="@+id/photoScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="50dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="50dp"

        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/layoutPhotoUpload1"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_photo_upload_box"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivPhotoPreview1"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_menu_camera" />

                <TextView
                    android:id="@+id/tvPhotoCount1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/5" />
            </LinearLayout>



        </LinearLayout>
    </HorizontalScrollView>

    <CheckBox
        android:id="@+id/checkRemoveBg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:buttonTint="#8A8A8A"
        android:text="사진 배경 자동 제거하기"
        android:textColor="#111111"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/photoScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnDone"
        android:layout_width="95dp"
        android:layout_height="42dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_black_round_button"
        android:text="완료"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/checkRemoveBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSell"
        android:layout_width="170dp"
        android:layout_height="42dp"
        android:layout_marginBottom="42dp"
        android:background="@drawable/bg_gray_round_button"
        android:text="판매하기"
        android:textAllCaps="false"
        android:textColor="#111111"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>