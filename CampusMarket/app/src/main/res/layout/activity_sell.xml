<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"

    tools:context=".SellActivity"
    android:background="@drawable/detailbackgruound"
    >

    <!-- 뒤로가기 -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        android:contentDescription="뒤로가기"
        android:src="@drawable/icback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 사진 업로드 박스 -->
    <HorizontalScrollView
        android:id="@+id/photoScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="50dp"
        android:layout_marginTop="40dp"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:id="@+id/photoContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 사진 박스 1 (기본) -->
            <LinearLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_photo_upload_box"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_menu_camera" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/5" />
            </LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- 체크박스 -->
    <CheckBox
        android:id="@+id/checkRemoveBg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:buttonTint="#8A8A8A"
        android:text="사진 배경 자동 제거하기"
        android:textColor="#111111"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/photoScroll"        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 완료 버튼 -->
    <Button
        android:id="@+id/btnDone"
        android:layout_width="95dp"
        android:layout_height="42dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_black_round_button"
        android:text="완료"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/checkRemoveBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 판매하기 버튼 -->
    <Button
        android:id="@+id/btnSell"
        android:layout_width="170dp"
        android:layout_height="42dp"
        android:layout_marginBottom="42dp"
        android:background="@drawable/bg_gray_round_button"
        android:text="판매하기"
        android:textAllCaps="false"
        android:textColor="#111111"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>