<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/detailbackgruound">

    <!-- 스크롤 영역 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="200dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ================= padding 영역 시작 ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="30dp"
                android:paddingStart="60dp"
                android:paddingEnd="60dp"
                android:paddingTop="20dp">

                <!-- 제목 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 정보"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- 프로필 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_profile_circle" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:orientation="horizontal">

                            <Button
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="복복복단"
                                android:textAllCaps="false"
                                android:background="@drawable/bg_light_rounded_button"/>

                            <Button
                                android:layout_width="72dp"
                                android:layout_height="match_parent"
                                android:layout_marginStart="6dp"
                                android:text="랜덤"
                                android:textAllCaps="false"
                                android:textColor="#fff"
                                android:background="@drawable/bg_black_rounded_button"/>
                        </LinearLayout>

                        <Button
                            android:layout_width="90dp"
                            android:layout_height="36dp"
                            android:layout_marginTop="8dp"
                            android:text="연락하기"
                            android:textAllCaps="false"
                            android:textColor="#fff"
                            android:background="@drawable/bg_black_small_button"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- 관심 목록 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_light_big_round"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="관심 목록"/>


                </LinearLayout>

                <!-- 사물함 버튼 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="사물함"
                        android:background="@drawable/bg_light_pill_button"/>

                    <Button
                        android:layout_width="120dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:text="사물함 수정하기"
                        android:textColor="#fff"
                        android:background="@drawable/bg_black_rounded_button"/>
                </LinearLayout>

                <!-- 위치 텍스트 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="• 차미리사관 3층 t-07"/>

            </LinearLayout>
            <!-- ================= padding 영역 끝 ================= -->


            <!-- 🔥 이미지 (padding 없음!) -->
            <FrameLayout

                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"

                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_gray_placeholder" />

            <!-- ================= padding 영역 다시 시작 ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="60dp"
                android:paddingEnd="60dp">

                <!-- 시간표 버튼 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="시간표"
                        android:background="@drawable/bg_light_pill_button"/>

                    <Button
                        android:layout_width="120dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:text="시간표 수정하기"
                        android:textColor="#fff"
                        android:background="@drawable/bg_black_rounded_button"/>
                </LinearLayout>

            </LinearLayout>
            <FrameLayout

                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"

                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_gray_placeholder" />


        </LinearLayout>
    </ScrollView>

    <!-- 🔥 네비게이션 바 (고정) -->
    <LinearLayout
        android:id="@+id/NavBar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:weightSum="4"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 홈 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/ichome" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textSize="10sp"
                android:textColor="#AF6330"
                android:textStyle="bold"/>
        </LinearLayout>
        <!-- 채팅 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/icmymarket" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 상점"
                android:textSize="10sp"
                android:textColor="#999999"
                android:textStyle="bold"/>
        </LinearLayout>
        <!-- 채팅 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/icchat" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="채팅"
                android:textSize="10sp"
                android:textColor="#999999"/>
        </LinearLayout>

        <!-- MY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_myinfo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY"
                android:textSize="10sp"
                android:textColor="#999999"/>
        </LinearLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>