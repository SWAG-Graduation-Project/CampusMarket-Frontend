<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ivPopupBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/detailbackgruound" />

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="match_parent"
        android:layout_marginStart="35dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvStoreTitle"
            android:layout_width="140dp"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:background="#E6C7A0"
            android:gravity="center"
            android:text="수진이네 상점"
            android:textColor="#3A2A1C"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="300dp"
            android:layout_height="200dp"

            android:layout_marginTop="40dp"
            android:background="#D9D4CE"
            android:scaleType="centerCrop" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvDate"
                android:layout_marginEnd="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="상품 이름 상품 이름상품 이름 상품 이름상품 이름 상품 이름"
                android:textColor="#3A2A1C"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="07.21"
                android:textColor="#7E746B"
                android:textSize="11sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="15,000원"
            android:textColor="#8B4B1F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/tagContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tagCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_gray"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="가방"
                android:textColor="#5F5A56"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tagState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tag_green"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="양호"
                android:textColor="#4B6B4C"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tagColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tag_brown"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="갈색"
                android:textColor="#5A3A28"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:text="탈취 청소와 전자기기 관리에 최적화된 초미세 면봉입니다. 총 400개입인 점탑형 제품으로 빈 캔 구매하시면 넉넉하게 사용하실 수 있습니다. 제품 길이는 약 7cm이며 면봉 머리가 아주 짧아 정밀한 청소가 가능합니다. 미개봉 새 제품이며 청소 용도로 사용하실 분께 추천드립니다."
            android:textColor="#4B4036"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/bottomButtonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnChat"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_popup_btn_light"
                android:text="채팅하기"
                android:textColor="#3A2A1C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLike"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_popup_btn_light"
                android:text="관심 24"
                android:textColor="#3A2A1C"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>